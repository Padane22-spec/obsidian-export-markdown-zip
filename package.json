{
  "name": "obsidian-share-markdown-zip",
  "version": "0.1.6",
  "description": "Obsidian plugin to export a note with linked notes and local attachments into a zip archive.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "markdown",
    "zip"
  ],
  "author": "padane22",
  "license": "GPL-3.0-only",
  "dependencies": {
    "jszip": "^3.10.1",
    "obsidian": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.13.14",
    "esbuild": "^0.25.1",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.0.8"
  }
}
